<Window x:Class="MojaBiblioteka.MVP.RegistrationView.View.RegistrationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MojaBiblioteka.MVP.RegistrationView.View"
        mc:Ignorable="d"
        Title="RegistrationForm" Height="470" Width="300" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" BorderThickness="0" WindowStyle="None" >
    <Grid Background="WhiteSmoke" HorizontalAlignment="Center" Width="300">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Margin="50,10" CornerRadius="30,1,30,1" Background ="Purple">
            <TextBlock Text="Rejestracja" HorizontalAlignment="Center" VerticalAlignment="Center" 
                   Foreground="White" FontSize="24" FontWeight="Bold" Padding="0,10"/>
        </Border>
        <Label Grid.Row="0" Grid.Column="2" Content="X" 
            HorizontalAlignment="Right" VerticalAlignment="Top"  
            Foreground="Crimson" FontSize="16" FontWeight="SemiBold" Margin="0, 5, 5 ,0" MouseDown="lblClose_Click"/>

        <Label Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.ColumnSpan="2" FontSize="30" Foreground="Purple" FontWeight="Bold" Margin="0,20,0,0">Moja biblioteka</Label>
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Login:" 
               HorizontalAlignment="Left" Margin="31,30,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="3" Grid.ColumnSpan="2" Name ="txtLogin"  Margin="30,0,30,15" 
             Padding="10" FontSize="14" BorderBrush="Gray"  BorderThickness="1" 
             VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="5" 
               HorizontalAlignment="Left" Margin="30,21,0,79" FontWeight="SemiBold" Grid.RowSpan="3"><Run Language="pl-pl" Text="Powtórz h"/><Run Text="asło:"/></TextBlock>
        <PasswordBox Grid.Row="4" Grid.ColumnSpan="2" Name ="txtPassword" Margin="30,22,30,48" 
                 Padding="10" FontSize="14" BorderBrush="Gray" BorderThickness="1" Background="White" 
                 VerticalContentAlignment="Center" Grid.RowSpan="2"/>

        <TextBlock Grid.Row="4" Text="Hasło:" 
               HorizontalAlignment="Left" Margin="30,4,0,1" FontWeight="SemiBold" RenderTransformOrigin="0.501,-0.172"/>
        <PasswordBox Grid.Row="5" Grid.ColumnSpan="2" Name ="txtConfirmationPassword" Margin="31,38,29,32" 
                 Padding="10" FontSize="14" BorderBrush="Gray" BorderThickness="1" Background="White" 
                 VerticalContentAlignment="Center" Grid.RowSpan="2"/>

        <Button Grid.Row="6" Grid.ColumnSpan="2" Content="Zarejestruj się" 
            HorizontalAlignment="Left" VerticalAlignment="Top" Width="150" Height="40" Background="Purple" Foreground="White" BorderThickness="0" 
            FontSize="16" FontWeight="SemiBold" Click="btnRegister_Click" Margin="74,39,0,0" Grid.RowSpan="2"/>

        <Label Grid.Row="7" Grid.ColumnSpan="2" Content="Wróć do logowania" 
            HorizontalAlignment="Left" VerticalAlignment="Top"  
            Foreground="Purple" FontSize="16" FontWeight="SemiBold" MouseDown="lblReturnToLoginForm_Click" Margin="74,36,0,0" Grid.RowSpan="2"/>
    </Grid>
</Window>
