<Window x:Class="MojaBiblioteka.MVP.LoginView.View.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie" Height="400" Width="300" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" BorderThickness="0" WindowStyle="None" >
    
    <Grid Background="WhiteSmoke" HorizontalAlignment="Center" Width="300">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Margin="50,10" CornerRadius="30,1,30,1" Background ="Purple">
            <TextBlock Text="Logowanie" HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Foreground="White" FontSize="24" FontWeight="Bold" Padding="0,10"/>
        </Border>
        <Label Grid.Row="0" Grid.Column="2" Content="X" 
                HorizontalAlignment="Right" VerticalAlignment="Top"  
                Foreground="Crimson" FontSize="16" FontWeight="SemiBold" Margin="0, 5, 5 ,0" MouseDown="lblClose_Click"/>
        
        <Label Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.ColumnSpan="2" FontSize="30" Foreground="Purple" FontWeight="Bold" Margin="0,20,0,0">Moja biblioteka</Label>
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Login:" 
                   HorizontalAlignment="Left" Margin="31,30,0,5" FontWeight="SemiBold"/>
        <TextBox x:Name="txtLogin" Grid.Row="3" Grid.ColumnSpan="2" Margin="30,0,30,15" 
                 Padding="10" FontSize="14" BorderBrush="Gray"  BorderThickness="1" 
                 VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Hasło:" 
                   HorizontalAlignment="Left" Margin="31,0,0,5" FontWeight="SemiBold"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="5" Grid.ColumnSpan="2" Margin="30,0,30,20" 
                     Padding="10" FontSize="14" BorderBrush="Gray" BorderThickness="1" Background="White" 
                     VerticalContentAlignment="Center"/>

        <Button Grid.Row="6" Grid.ColumnSpan="2" Content="Zaloguj się" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Height="40" Background="Purple" Foreground="White" BorderThickness="0" 
                FontSize="16" FontWeight="SemiBold" Click="Button_Login_Click"/>

        <Label Grid.Row="7" Grid.ColumnSpan="2" Content="Zarejestruj się" 
                HorizontalAlignment="Center" VerticalAlignment="Center"  
                Foreground="Purple" FontSize="16" FontWeight="SemiBold" MouseDown="lblRegister_Click"/>
    </Grid>
</Window>
